{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext", // Permite usar import/export modernos
    "moduleResolution": "bundler", // O segredo! Resolve caminhos sem precisar de .js
    "allowImportingTsExtensions": true, // Se precisares de importar .ts explicitamente
    "noEmit": true, // Como usamos o TSX, não precisamos que o TS gere arquivos .js
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
